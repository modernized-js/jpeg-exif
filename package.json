{
  "name": "@modernized/jpeg-exif",
  "version": "2.0.0",
  "description": "Get EXIF/TIFF metadata from JPEG and TIFF files. Maintained fork of `jpeg-exif`.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/cjs",
    "dist/esm",
    "src",
    "!src/**/*.map",
    "README.md",
    "LICENSE.txt"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint src test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"const f=require('node:fs');f.rmSync('dist',{recursive:true,force:true});f.rmSync('dist-test',{recursive:true,force:true})\"",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:shims": "node -e \"const f=require('node:fs');f.writeFileSync('dist/cjs/package.json',JSON.stringify({type:'commonjs'}));f.writeFileSync('dist/esm/package.json',JSON.stringify({type:'module'}))\"",
    "build": "yarn clean && yarn build:cjs && yarn build:esm && yarn build:shims",
    "build:test": "tsc -p tsconfig.test.json",
    "pretest": "yarn build:test",
    "test": "node --test \"dist-test/test/**/*.test.js\"",
    "coverage": "node --test --experimental-test-coverage \"dist-test/test/**/*.test.js\"",
    "precoverage:check": "yarn build:test",
    "coverage:check": "node --test --experimental-test-coverage --test-coverage-lines=90 --test-coverage-branches=70 --test-coverage-functions=90 \"dist-test/test/**/*.test.js\"",
    "prepack": "yarn build"
  },
  "keywords": [
    "jpeg",
    "exif",
    "gps",
    "image",
    "picture",
    "photo",
    "jfif",
    "tiff"
  ],
  "homepage": "https://github.com/modernized-js/jpeg-exif",
  "repository": {
    "type": "git",
    "url": "https://github.com/modernized-js/jpeg-exif.git"
  },
  "bugs": {
    "url": "https://github.com/modernized-js/jpeg-exif/issues"
  },
  "author": "isamu",
  "contributors": [
    "zhso <s@zhso.net> (original author)"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
